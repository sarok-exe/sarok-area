#!/usr/bin/env bash
WALL="${1:-}"

if [ -z "$WALL" ]; then
  WALL=$(ps aux | grep -E "swaybg|mpvpaper" | grep -v grep | tr ' ' '\n' | grep -E '\.(jpg|png|jpeg|gif)' | head -1)
fi

[ -z "$WALL" ] && echo "No wallpaper found" && exit 1
[ ! -f "$WALL" ] && echo "File not found: $WALL" && exit 1

matugen image "$WALL" --prefer darkness --json hex 2>/dev/null > /tmp/matugen_out.json
~/.config/Scripts/gen-kitty-theme.py > ~/.config/kitty/theme.conf