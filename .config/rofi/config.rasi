@import "colors.rasi"

configuration {
    modi: "drun";
    show-icons: true;
    display-drun: "Apps";
}

listview {
    lines: 8;
}

element {
    padding: 8px;
    border-radius: 6px;
}

element selected {
    background-color: #ffb4a4;
    text-color: #1a1a1a;
}

element hover {
    background-color: #333333;
}